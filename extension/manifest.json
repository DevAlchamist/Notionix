{
  "manifest_version": 3,
  "name": "AI Conversation Summarizer",
  "description": "Summarize AI chat conversations on ChatGPT, Claude, and Gemini and save them to your personal knowledge archive.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Remember"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "identity",
    "windows"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://accounts.google.com/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://copilot.microsoft.com/*",
    "https://www.bing.com/*",
    "https://grok.com/*",
    "https://x.com/i/grok*"
  ],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "dist/content-chatgpt.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": [
        "dist/content-claude.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": [
        "dist/content-gemini.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://copilot.microsoft.com/*",
        "https://www.bing.com/*"
      ],
      "js": [
        "dist/content-bing.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://grok.com/*",
        "https://x.com/i/grok*"
      ],
      "js": [
        "dist/content-grok.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
